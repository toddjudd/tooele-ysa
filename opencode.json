{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "convex": {
      "type": "local",
      "command": ["npx", "-y", "convex@latest", "mcp", "start"],
      "enabled": true
    },
    "posthog": {
      "type": "local",
      "command": [
        "op",
        "run",
        "--account",
        "JOBLWRURS5GHFCG3CW5TR7YHAE",
        "--",
        "npx",
        "-y",
        "@arvoretech/posthog-mcp"
      ],
      "enabled": true,
      "environment": {
        "POSTHOG_BASE_URL": "https://us.posthog.com",
        "POSTHOG_API_KEY": "op://Private/Posthog/add more/api_key"
      }
    }
  },
  "agent": {
    "epic-runner": {
      "description": "Orchestrates full epic execution: dev → review → re-dev loops per story",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:.opencode/agents/epic-runner.md}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "allow",
        "skill": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    }
  }
}
